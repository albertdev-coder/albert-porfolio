---
import { Icon } from "astro-icon/components";
import quizImg1 from "../assets/quizz-ciencia-1.png";
import quizImg2 from "../assets/quizz-ciencia-2.png";
import quizImg3 from "../assets/quizz-ciencia-3.png";

import bit1 from "../assets/bitverso-1.png";
import bit2 from "../assets/bitverso-2.png";
import bit3 from "../assets/bitverso-3.png";

import "photoswipe/style.css";

import type { ImageMetadata } from "astro";

type Project = {
  title: string;
  description: string;
  details: string;
  stack: string[];
  screenshots: ImageMetadata[];
  link: string;
  github: string;
  featured?: boolean;
};

const projects: Project[] = [
  {
    title: "Educational PWA Platform",
    description: "A compact PWA for structured web-development courses with interactive exercises.",
    details: "Problem: Provide a lightweight, offline-capable learning platform for students with limited bandwidth. Tech & Architecture: Next.js (frontend SSR/SSG), React, TypeScript, Node.js + Express API, PostgreSQL. Features: offline support (PWA), course progress sync, lesson quizzes, admin panel for content management. My contribution: full-stack implementation of course flow, API endpoints, and deployment on Vercel/Railway.",
    stack: ["TypeScript", "React", "Next.js", "Tailwind CSS", "Node.js", "PostgreSQL"],
    screenshots: [bit1, bit2, bit3],
    link: "https://bitverso-one.vercel.app",
    github: "https://github.com/albertdev-coder/course-pwa",
    featured: true,
  },
  {
    title: "Interactive Quiz Application",
    description: "Minimal science quiz app with multiple difficulty levels and adaptive scoring.",
    details: "Problem: Create a responsive quiz app that adapts question difficulty and keeps user progress. Tech & Architecture: Next.js frontend, client-side React state, Express API for results and leaderboards, PostgreSQL for persistence. Features: timed quizzes, adaptive difficulty, results/history, responsive UI and PWA-friendly UI. My contribution: quiz engine, adaptive logic, API endpoints and Railway deployment.",
    stack: ["TypeScript", "React", "Next.js", "Tailwind CSS", "Node.js", "PostgreSQL"],
    screenshots: [quizImg1, quizImg2, quizImg3],
    link: "https://quizz-ciencia.up.railway.app",
    github: "https://github.com/albertdev-coder/lol-quizz",
    featured: true,
  },
];
---

<section id="projects" class="relative py-20 md:py-32">
  <div class="container-custom">
    <div class="text-center mb-16" data-animate="fade-in">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">
        <span class="text-gradient">Featured Projects</span>
      </h2>
      <div class="h-1 w-20 mx-auto bg-gradient-to-r from-crystal-purple to-crystal-pink rounded-full mb-6"></div>
      <p class="text-lg text-text-tertiary max-w-2xl mx-auto">
        Selected full-stack projects showcasing scalable architecture and modern web technologies.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8">
      {projects.map((project, index) => (
        <article
          class="group glass rounded-2xl overflow-hidden transition-all duration-500 hover:scale-[1.02]"
          data-animate="slide-up"
          data-delay={index * 120}
          aria-labelledby={`project-title-${index}`}
        >
          <div class="relative overflow-hidden bg-gradient-to-br from-crystal-blue/10 to-crystal-purple/10">
            <div
              class="pswp-gallery grid grid-cols-2 md:grid-cols-3 gap-2 p-3"
              id={`gallery-${index}`}
              aria-hidden="false"
            >
              {project.screenshots.map((img, i) => (
                <a
                  href={img.src}
                  data-pswp-width={img.width || 1200}
                  data-pswp-height={img.height || 800}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block rounded-lg overflow-hidden cursor-zoom-in aspect-[4/3]"
                  data-caption={`${project.title} — Screenshot ${i + 1}`}
                >
                  <img
                    src={img.src}
                    alt={`${project.title} screenshot ${i + 1}`}
                    loading="lazy"
                    decoding="async"
                    class="object-cover w-full h-full rounded-lg hover:scale-105 transition-transform duration-300"
                  />
                </a>
              ))}
            </div>

            {project.featured && (
              <div class="absolute top-4 right-4 glass px-3 py-1 rounded-full text-xs font-semibold text-crystal-cyan flex items-center gap-1">
                <Icon name="lucide:star" class="w-3 h-3" aria-hidden="true" />
                <span class="sr-only">Featured project</span>
                <span>Featured</span>
              </div>
            )}
          </div>

          <div class="p-6 space-y-4">
            <div class="flex items-start justify-between">
              <h3 id={`project-title-${index}`} class="text-xl md:text-2xl font-bold group-hover:text-gradient">
                {project.title}
              </h3>

              <div class="flex gap-2">
                <a
                  href={project.link}
                  target="_blank"
                  class="glass glass-hover p-2 rounded-lg hover:crystal-glow-cyan"
                  aria-label={`Open ${project.title} live demo`}
                  rel="noopener noreferrer"
                >
                  <Icon name="lucide:external-link" class="w-5 h-5" />
                </a>

                <a
                  href={project.github}
                  target="_blank"
                  class="glass glass-hover p-2 rounded-lg hover:crystal-glow-cyan"
                  aria-label={`Open ${project.title} source code on GitHub`}
                  rel="noopener noreferrer"
                >
                  <Icon name="lucide:github" class="w-5 h-5" />
                </a>
              </div>
            </div>

            <p class="text-text-secondary">{project.description}</p>

            <div class="flex flex-wrap gap-2" aria-hidden="false">
              {project.stack.map((tech) => (
                <span class="glass px-3 py-1 rounded-full text-sm text-text-tertiary">
                  {tech}
                </span>
              ))}
            </div>

            <details class="mt-2">
              <summary class="cursor-pointer text-sm font-medium text-text-primary">Project details</summary>
              <div class="mt-2 text-sm text-text-secondary">
                {project.details}
              </div>
            </details>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script type="module">
  import PhotoSwipeLightbox from "photoswipe/lightbox";

  document.addEventListener("DOMContentLoaded", () => {
    const galleries = document.querySelectorAll(".pswp-gallery");

    galleries.forEach((gallery) => {
      if (!(gallery instanceof HTMLElement)) return;

      const lightbox = new PhotoSwipeLightbox({
        gallery,
        children: "a",
        pswpModule: () => import("photoswipe"),
        showHideAnimationType: "fade",
        bgOpacity: 0.9,
        padding: { top: 60, bottom: 60, left: 20, right: 20 },
        wheelToZoom: true,
        clickToCloseNonZoomable: true,
        imageClickAction: "zoom",
        bgClickAction: "close",
        preloaderDelay: 0,
        maxWidthToAnimate: 2500,
      });

      lightbox.init();
    });
  });
</script>

<style>
  #projects [data-animate] {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }
  #projects [data-animate].animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  .pswp-gallery a {
    display: block;
    width: 100%;
  }
  .pswp-gallery img {
    display: block;
    object-fit: cover;
    width: 100%;
    height: 100%;
  }

  details summary {
    list-style: none;
  }
  details[open] summary::after {
    content: "▲";
    float: right;
  }
  details summary::after {
    content: "▼";
    float: right;
  }

  /* Make grid responsive for mobile/tablet */
  @media (max-width: 768px) {
    .pswp-gallery {
      grid-template-columns: repeat(2, 1fr);
    }
    .pswp-gallery a {
      aspect-ratio: 4 / 3;
    }
  }

  @media (max-width: 480px) {
    .pswp-gallery {
      grid-template-columns: 1fr;
    }
    .pswp-gallery a {
      aspect-ratio: 16 / 9;
    }
  }
</style>
